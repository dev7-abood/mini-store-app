# Telegram bot token from @BotFather.
# No VITE_ prefix = server-side only: read exclusively by the Vercel
# serverless function in api/telegram-order.js, never bundled for the
# browser. Set it in Vercel -> Settings -> Environment Variables too.
BOT_TOKEN=123456789:AA...

# Optional: restaurant/admin chat id that receives a copy of every order.
ADMIN_CHAT_ID=

# Base URL of the Laravel backend API (public endpoint, safe to expose).
VITE_API_BASE_URL=https://your-backend.example.com/api/mini-app
