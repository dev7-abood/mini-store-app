# XOR key for decoding the deep-link payload (start_param).
# MUST equal TELEGRAM_DEEP_LINK_KEY on the backend. Not a real secret:
# used for routing only — authenticity comes from the initData HMAC.
VITE_TELEGRAM_DEEP_LINK_KEY=change-me-32-chars

# Optional: fixed API base URL for local dev / single-tenant mode.
# In multi-tenant mode the URL comes from the deep-link payload.
VITE_API_BASE_URL=

# Bot token — only for the demo Vercel function api/telegram-order.js
# (single-bot setups). In multi-tenant mode, send the order message from
# the TENANT backend (Laravel) — each restaurant's token lives there.
BOT_TOKEN=
ADMIN_CHAT_ID=
