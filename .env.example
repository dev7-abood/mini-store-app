# Telegram bot token from @BotFather.
# Server-side only (no NEXT_PUBLIC_ prefix) — never shipped to the browser.
BOT_TOKEN=123456789:AA...

# Optional: restaurant/admin chat id that receives a copy of every order.
# (Send /start to @userinfobot to get a chat id.)
ADMIN_CHAT_ID=

# Base URL of the Laravel backend API, proxied via /backend/* rewrite.
API_BASE_URL=https://your-backend.example.com/api/mini-app
