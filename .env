# مفتاح فك تشفير حمولة الرابط العميق (start_param) — نفس قيمة
# TELEGRAM_DEEP_LINK_KEY في الباك اند. ليس سراً حقيقياً: يُستخدم للتوجيه فقط،
# والموثوقية تأتي من توقيع initData الذي يتحقق منه الباك اند.
VITE_TELEGRAM_DEEP_LINK_KEY=

# (اختياري) رابط API ثابت للتطوير المحلي / وضع المستأجر الواحد.
# في الوضع متعدد المستأجرين يُحدد الرابط تلقائياً من حمولة الرابط العميق.
VITE_API_BASE_URL=

# توكن البوت — فقط لدالة Vercel التجريبية api/telegram-order.js (بوت واحد).
# في الوضع متعدد المستأجرين أرسل رسالة الطلب من باك اند المستأجر (Laravel)
# لأن التوكن الخاص بكل مطعم موجود هناك.
BOT_TOKEN=
ADMIN_CHAT_ID=

# Prefix appended to the deep-link tenant URL (default /api/v1).
VITE_API_PREFIX=/api/v1
